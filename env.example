# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product IDs (create these in Stripe Dashboard)
STRIPE_PRICE_ID_TIER_1=price_tier1_10gbp
STRIPE_PRICE_ID_TIER_2=price_tier2_25gbp
STRIPE_PRICE_ID_TIER_3=price_tier3_50gbp
STRIPE_PRICE_ID_TIER_4=price_tier4_100gbp

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Business Configuration
BUSINESS_NAME="New Forest Device Repairs"
BUSINESS_EMAIL=support@newforestdevicerepairs.co.uk
BUSINESS_PHONE=+44 1234 567890

# Feature Flags (optional)
ENABLE_SMS_LOGIN=false
ENABLE_NFC=false
